{
  "layer": "top",
  "position": "top",
  "margin-top": 4,
  "margin-left": 8,
  "margin-right": 8,
  "height": 28,
  "spacing": 4,

  "modules-left": [
    "hyprland/workspaces",
    "clock",
    "custom/power"
  ],

  "modules-right": [
    "custom/cpu",
    "memory",
    "custom/disk",
    "custom/gpu",
    "network",
    "bluetooth",
    "battery",
    "pulseaudio",
    "backlight",
    "tray",
    "custom/language"
  ],

  // ── Power / Session Menu ──────────────────────────────
  "custom/power": {
    "format": "󰐥",
    "tooltip": false,
    "menu": "on-click",
    "menu-file": "~/.config/waybar/power_menu.xml",
    "menu-actions": {
      "lock":     "hyprlock",
      "logout":   "hyprctl dispatch exit",
      "reboot":   "systemctl reboot",
      "shutdown": "systemctl poweroff"
    }
  },

  // ── Workspaces ──────────────────────────────────────
  "hyprland/workspaces": {
    "format": "{icon}",
    "format-icons": {
      "active":  "",
      "default": "·",
      "urgent":  ""
    },
    "on-scroll-up":   "hyprctl dispatch workspace e+1",
    "on-scroll-down": "hyprctl dispatch workspace e-1",
    "persistent-workspaces": {
      "*": 5
    }
  },

  // ── Clock ────────────────────────────────────────────
  "clock": {
    "format": "󰃰  {:%a %d %b  %I:%M:%S %p}",
    "interval": 1,
    "tooltip-format": "<tt>{calendar}</tt>",
    "calendar": {
      "mode": "month",
      "weeks-pos": "left",
      "format": {
        "today": "<span color='#AAD94C'><b>{}</b></span>"
      }
    }
  },

  // ── CPU ──────────────────────────────────────────────
  "custom/cpu": {
    "exec":        "~/.config/waybar/scripts/cpu-status.py",
    "return-type": "json",
    "interval":    2,
    "format":      "{}",
    "tooltip":     true
  },

  // ── Memory ───────────────────────────────────────────
  "memory": {
    "interval": 5,
    "format": "󰘚  {percentage}%",
    "states": { "warning": 70, "critical": 85 },
    "tooltip-format": "RAM\n  Used:   {used:0.1f}G\n  Free:   {avail:0.1f}G\n  Total:  {total:0.1f}G\n\nSwap\n  Used:   {swapUsed:0.1f}G\n  Free:   {swapAvail:0.1f}G\n  Total:  {swapTotal:0.1f}G"
  },

  // ── Disk ─────────────────────────────────────────────
  "custom/disk": {
    "exec":        "~/.config/waybar/scripts/disk-status.py",
    "return-type": "json",
    "interval":    30,
    "format":      "{}",
    "tooltip":     true
  },

  // ── GPU ──────────────────────────────────────────────
  "custom/gpu": {
    "exec":        "~/.config/waybar/scripts/gpu-status.py",
    "return-type": "json",
    "interval":    2,
    "format":      "{}",
    "tooltip":     true
  },

  // ── Network ──────────────────────────────────────────
  "network": {
    "interval": 2,
    "format-wifi":        "󰤨  {essid}  󰇚 {bandwidthDownBytes}  󰕒 {bandwidthUpBytes}",
    "format-ethernet":    "󰈀  󰇚 {bandwidthDownBytes}  󰕒 {bandwidthUpBytes}",
    "format-disconnected":"󰤭  Disconnected",
    "tooltip-format":     "Network\n  Interface:  {ifname}\n  IP:         {ipaddr}\n  Gateway:    {gwaddr}\n  Signal:     {signalStrength}%",
    "on-click":           "nm-connection-editor"
  },

  // ── Bluetooth ────────────────────────────────────────
  "bluetooth": {
    "format":                             "󰂯  {status}",
    "format-connected":                   "󰂱  {device_alias}",
    "format-connected-battery":           "󰂱  {device_alias}  {device_battery_percentage}%",
    "format-off":                         "󰂲  Off",
    "tooltip-format":                     "Bluetooth\n  Controller:  {controller_alias}  ({controller_address})",
    "tooltip-format-connected":           "Bluetooth\n  Controller:  {controller_alias}\n  Devices:     {num_connections}\n{device_enumerate}",
    "tooltip-format-enumerate-connected": "    •  {device_alias}  ({device_address})",
    "on-click":                           "blueman-manager"
  },

  // ── Battery ──────────────────────────────────────────
  "battery": {
    "states": { "warning": 20, "critical": 10 },
    "format":          "{icon}  {capacity}%",
    "format-charging": "󰂄  {capacity}%",
    "format-icons":    ["󰂎","󰁺","󰁻","󰁼","󰁽","󰁾","󰁿","󰂀","󰂁","󰂂","󰁹"],
    "tooltip-format":  "Battery\n  Charge:  {capacity}%\n  Time:    {timeTo}\n  Power:   {power}W"
  },

  // ── Audio ─────────────────────────────────────────────
  "pulseaudio": {
    "scroll-step": 5,
    "format":       "{icon}  {volume}%",
    "format-muted": "󰝟  Muted",
    "format-icons": { "default": ["󰕿","󰖀","󰕾"] },
    "tooltip-format": "Audio\n  Volume:  {volume}%\n  Device:  {desc}",
    "on-click":        "pavucontrol",
    "on-click-right":  "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle"
  },

  // ── Backlight ─────────────────────────────────────────
  "backlight": {
    "device":         "nvidia_0",
    "format":         "{icon}  {percent}%",
    "format-icons":   ["󰃞","󰃟","󰃠"],
    "on-scroll-up":   "brightnessctl set +5%",
    "on-scroll-down": "brightnessctl set 5%-",
    "on-click":       "cur=$(brightnessctl get); max=$(brightnessctl max); [ $((cur * 100 / max)) -gt 50 ] && brightnessctl set 50% || brightnessctl set 100%",
    "tooltip":        false
  },

  // ── Language ─────────────────────────────────────────
  "custom/language": {
    "exec": "layout=$(hyprctl devices -j | jq -r '[.keyboards[] | select(.main == true) | .active_keymap][0]'); [[ \"$layout\" == *Arabic* ]] && echo '󰌌  AR' || echo '󰌌  EN'",
    "interval": 1,
    "on-click": "hyprctl switchxkblayout all next",
    "tooltip": false
  },

  // ── Tray ─────────────────────────────────────────────
  "tray": {
    "spacing": 8
  }
}
